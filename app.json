{
  "expo": {
    "scheme": "spillr",
    "name": "SpillR-app",
    "slug": "SpillR-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/transparent-logo-example.png",
      "resizeMode": "contain",
      "backgroundColor": "#E63E53"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ss21.SpillRapp",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4d39f966-f690-47df-9e8b-00f062a21a8b"
      }
    }
  }
}
