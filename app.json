{
  "expo": {
    "scheme": "spillr",
    "name": "SpillR-app",
    "slug": "SpillR-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/transparent-logo-example.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF7AF3"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ss21.SpillRapp",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#E6F4FE"
      },
      "package": "com.ss21.SpillRapp"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e373913c-1125-466f-a6b9-989643f8f2d2"
      }
    },
    "owner": "jeffsun93"
  }
}
